#include <stdio.h>
#include <stdlib.h>
#include <unistd.h>
#include <sys/shm.h>
#include <sys/ipc.h>
#include <sys/wait.h>

int main()
{
    int pid, shmid, i;
    key_t key = 2041;
    char *shmptr;

    /* Create shared memory */
    shmid = shmget(key, 32, 0666 | IPC_CREAT);
    if (shmid < 0) {
        perror("shmget failed");
        exit(1);
    }

    pid = fork();

    if (pid < 0) {
        perror("fork failed");
        exit(1);
    }

    /* Parent Process */
    if (pid > 0) {
        shmptr = (char *)shmat(shmid, NULL, 0);
        if (shmptr == (char *)-1) {
            perror("shmat failed");
            exit(1);
        }

        printf("\nPARENT PROCESS WRITING\n");
        for (i = 0; i < 10; i++) {
            shmptr[i] = 'a' + i;
            putchar(shmptr[i]);
        }

        shmptr[10] = '\0';   // Null terminate string
        printf("\n\n%s\n", shmptr);

        wait(NULL);          // Wait for child

        shmdt(shmptr);       // Detach memory
    }
    /* Child Process */
    else {
        sleep(1);  // Ensure parent writes first

        shmptr = (char *)shmat(shmid, NULL, 0);
        if (shmptr == (char *)-1) {
            perror("shmat failed");
            exit(1);
        }

        printf("\nCHILD PROCESS READING\n");
        for (i = 0; i < 10; i++)
            putchar(shmptr[i]);

        printf("\n");

        shmdt(shmptr);                 // Detach
        shmctl(shmid, IPC_RMID, NULL); // Remove shared memory
    }

    return 0;
}
