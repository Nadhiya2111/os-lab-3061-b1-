#include <stdio.h>

int main() {
    int i, j, k = 0, tp, tr, found, flag;
    int p[10][10], c[10][10], m[10], finish[10] = {0};
    int r[10], a[10], temp[10];

    printf("Enter total no of processes: ");
    scanf("%d", &tp);
    printf("Enter total no of resources: ");
    scanf("%d", &tr);

    printf("Enter Maximum Claim matrix:\n");
    for (i = 0; i < tp; i++) {
        printf("Process %d: ", i);
        for (j = 0; j < tr; j++)
            scanf("%d", &c[i][j]);
    }

    printf("Enter Allocation matrix:\n");
    for (i = 0; i < tp; i++) {
        printf("Process %d: ", i);
        for (j = 0; j < tr; j++)
            scanf("%d", &p[i][j]);
    }

    printf("Enter availability vector: ");
    for (i = 0; i < tr; i++) {
        scanf("%d", &a[i]);
        temp[i] = a[i];
    }

    for (int count = 0; count < tp; count++) {
        for (i = 0; i < tp; i++) {
            if (finish[i] == 0) {
                flag = 1;
                for (j = 0; j < tr; j++) {
                    if ((c[i][j] - p[i][j]) > temp[j]) {
                        flag = 0;
                        break;
                    }
                }
                if (flag == 1) {
                    for (j = 0; j < tr; j++)
                        temp[j] += p[i][j];
                    finish[i] = 1;
                    m[k++] = i;
                }
            }
        }
    }

    printf("\nDeadlock causing processes: ");
    found = 0;
    for (i = 0; i < tp; i++) {
        if (finish[i] == 0) {
            printf("P%d ", i);
            found = 1;
        }
    }

    if (found == 0) printf("None");
    
    return 0;
}
